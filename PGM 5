        AREA PGM1, CODE, READONLY

DIVIDEND   RN 1
DIVISOR    RN 2
QUOTIENT   RN 3
REMAINDER  RN 4
RESULT     RN 5

        ENTRY

        MOV DIVIDEND, #123
        MOV DIVISOR, #10
        MOV RESULT, #0

LOOP
        BL DIV

        ADD RESULT, RESULT, REMAINDER

        CMP QUOTIENT, #0
        MOV DIVIDEND, QUOTIENT
        BNE LOOP

STOP
        B STOP

DIV
        MOV QUOTIENT, #0

LOOP2
        SUBS DIVIDEND, DIVIDEND, DIVISOR
        ADDPL QUOTIENT, QUOTIENT, #1
        BPL LOOP2

        ADDMI REMAINDER, DIVIDEND, DIVISOR
        BX LR

        END
