#include <LPC214x.h>

void init()
{
    PINSEL0 = 0x00050000;

    U1FCR = 0x07;
    U1LCR = 0x83;

    U1DLL = 0x61;
    U1DLM = 0x00;

    U1LCR = 0x03;
}

void delay()
{
    int i;

    for(i = 0; i < 250; i++);
}

int main()
{
    unsigned char p[] = "I LOVE ISE\n";
    int z;

    init();

    for(z = 0; p[z] != '\0'; z++)
    {
        U1THR = p[z];

        while(!(U1LSR & 0x20));

        delay();
    }

    while(1);
}
