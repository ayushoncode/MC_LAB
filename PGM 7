        AREA PGM1, CODE, READONLY

DIVIDEND   RN 1
DIVISOR    RN 2
QUOTIENT   RN 3
REMAINDER  RN 4
N          RN 5
R          RN 6
NDR        RN 7

        ENTRY

        LDR R10, =0x40000000

        MOV N, #6
        MOV R, #3
        SUB NDR, N, R

        MOV DIVIDEND, N
        BL FACT
        MOV R8, DIVISOR

        MOV DIVIDEND, NDR
        BL FACT
        MOV R9, DIVISOR

        MOV DIVIDEND, R8
        MOV DIVISOR, R9
        BL DIV

        STR QUOTIENT, [R10]

STOP
        B STOP

FACT
        MOV DIVISOR, #1

LOOP
        MUL DIVISOR, DIVISOR, DIVIDEND
        SUBS DIVIDEND, DIVIDEND, #1
        BNE LOOP

        BX LR

DIV
        MOV QUOTIENT, #0

LOOP3
        SUBS DIVIDEND, DIVIDEND, DIVISOR
        ADDPL QUOTIENT, QUOTIENT, #1
        BPL LOOP3

        ADDMI DIVIDEND, DIVIDEND, DIVISOR
        MOV REMAINDER, DIVIDEND

        BX LR

        END
